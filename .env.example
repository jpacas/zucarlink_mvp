RESEND_FROM_EMAIL=no-reply@zucarlink.com
EMAIL_WEBHOOK_SECRET=

# Re-engagement (edge function engagement-emails, disparada por pg_cron) — Supabase Secret
ENGAGEMENT_CRON_SECRET=
