# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Observabilidad (opcional) — DSN del proyecto en sentry.io. Vacío = Sentry desactivado.
VITE_SENTRY_DSN=

# Supabase (CLI y migraciones locales)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email delivery — configurar como Supabase Secrets (no en Vercel)
